      ],
      "id": "f4b8c82c-17a0-4d6c-8761-eda72f60bf9d",
      "name": "Embed User Question"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.cohere.com/v1/embed",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ \"model\": \"embed-english-v3.0\", \"input_type\": \"search_query\", \"texts\": [$json.question] }) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        32,
        -64
      ],
      "id": "93f80f06-98de-4117-b518-bb0d291adf2f",
      "name": "Embed Question",
      "credentials": {
        "httpHeaderAuth": {
          "id": "YktK1yeKFk75UMdi",
          "name": "Cohere - Cognflow"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Get query embedding - use $json directly (input from Embed Question)\nconst queryEmbedding = $json.embeddings[0];\nconst question = $('Embed User Question').first().json.question;\n\n// Retrieve vector store from static data\nconst staticData = $getWorkflowStaticData('global');\nconst vectorStore = staticData.vectorStore;\n\nif (!vectorStore || vectorStore.length === 0) {\n  return [{ json: { error: 'Vector store is empty. Run the index build pipeline first.' } }];\n}\n\nfunction cosineSimilarity(a, b) {\n  let dot = 0, normA = 0, normB = 0;\n  for (let i = 0; i < a.length; i++) {\n    dot += a[i] * b[i];\n    normA += a[i] * a[i];\n    normB += b[i] * b[i];\n  }\n  return dot / (Math.sqrt(normA) * Math.sqrt(normB));\n}\n\nconst scored = vectorStore.map(chunk => ({\n  text: chunk.text,\n  source: chunk.source,\n  score: cosineSimilarity(queryEmbedding, chunk.embedding)\n}));\n\nconst topChunks = scored\n  .sort((a, b) => b.score - a.score)\n  .slice(0, 5);\n\nconst context = topChunks.map(c => c.text).join('\\n\\n');\n\nreturn [{ json: { question, context, topChunks } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
