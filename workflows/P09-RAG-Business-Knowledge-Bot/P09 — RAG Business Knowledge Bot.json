        "jsonBody": "={{ JSON.stringify({ \"model\": \"claude-sonnet-4-5\", \"max_tokens\": 1024, \"messages\": [{ \"role\": \"user\", \"content\": \"You are the Cognflow AI assistant. Answer the question using only the context below.\\n\\nContext:\\n\" + $('Similarity Search').item.json.context + \"\\n\\nQuestion: \" + $('Similarity Search').item.json.question }] }) }}",
