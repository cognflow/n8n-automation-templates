          "name": "Notion - Cognflow"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const blocks = items[0].json.results;\n\nconst chunks = [];\n\nfor (const block of blocks) {\n  const type = block.type;\n  const content = block[type];\n  \n  if (!content || !content.rich_text) continue;\n  \n  const text = content.rich_text\n    .map(rt => rt.plain_text)\n    .join('')\n    .trim();\n  \n  if (text.length === 0) continue;\n  \n  chunks.push({\n    json: {\n      text: text,\n      source: 'Cognflow SOPs',\n      block_id: block.id,\n      type: type\n    }\n  });\n}\n\nreturn chunks;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -80,
        112
      ],
      "id": "62947a7b-aca1-4065-8302-1adb07d05380",
      "name": "Extract + Chunk Text"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.cohere.com/v1/embed",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ \"model\": \"embed-english-v3.0\", \"input_type\": \"search_document\", \"texts\": $('Extract + Chunk Text').all().map(item => item.json.text) }) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
