        112
      ],
      "id": "32c77449-d4a9-4145-aabe-f1c6f4cc2ea7",
      "name": "Generate Embeddings",
      "executeOnce": true,
      "credentials": {
        "httpHeaderAuth": {
          "id": "YktK1yeKFk75UMdi",
          "name": "Cohere - Cognflow"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\n// All items coming in are the batched embedding response\n// The embeddings array contains all 26 vectors\nconst embeddingsData = items[0].json.embeddings;\nconst textsData = items[0].json.texts;\n\nconst vectorStore = [];\n\nfor (let i = 0; i < textsData.length; i++) {\n  vectorStore.push({\n    text: textsData[i],\n    embedding: embeddingsData[i],\n    source: 'Cognflow SOPs'\n  });\n}\n\nstaticData.vectorStore = vectorStore;\n\nreturn [{ json: { stored: vectorStore.length, status: 'Vector store built successfully' } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        256,
        112
      ],
      "id": "ea6bc0fd-539b-4be3-b36b-2aa5255c4d50",
      "name": "Build Vector Store"
    },
    {
      "parameters": {
        "jsCode": "const question = $('When chat message received').item.json.chatInput;\n\nreturn [{ json: { question: question } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -96,
