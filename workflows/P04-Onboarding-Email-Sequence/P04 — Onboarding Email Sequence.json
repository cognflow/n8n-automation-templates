    {
      "parameters": {
        "jsCode": "const name = $input.first().json.name;\nconst email = $input.first().json.email;\nconst plan_type = $input.first().json.plan_type;\nconst company = $input.first().json.company;\n\nreturn {\n  name,\n  email,\n  plan_type,\n  company,\n  email1_body: JSON.stringify({\n    model: \"claude-sonnet-4-5\",\n    max_tokens: 1000,\n    messages: [{\n      role: \"user\",\n      content: `You are a professional onboarding assistant for Cognflow, an AI automation agency. Write a warm, immediate welcome email for a new ${plan_type} plan signup. Name: ${name}. Company: ${company}. Keep it under 120 words. Include: a warm welcome, one sentence about what Cognflow automates for them, and one clear next step. No placeholders.`\n    }]\n  })\n};"
      },
