      "parameters": {
        "jsCode": "const sopClean = $json.sop_context.replace(/\\n/g, ' ').replace(/\"/g, \"'\");\nconst painClean = $json.pain_point.replace(/\\n/g, ' ').replace(/\"/g, \"'\");\n\nconst content = `You are a sales agent for Cognflow, an n8n automation agency.\\n\\nWrite a short personalised outreach email.\\n\\nLead:\\n- Name: ${$json.name}\\n- Business: ${$json.business}\\n- Pain Point: ${painClean}\\n- Suggested Service: ${$json.suggested_service}\\n- Score: ${$json.score}/10\\n\\nSOPs:\\n${sopClean}\\n\\nRequirements:\\n- Start with Subject: <subject line>\\n- Address by first name\\n- Reference their pain point\\n- Show how Cognflow solves it\\n- Under 150 words\\n- CTA to book discovery call\\n- Sign off: Samuel | Cognflow\\n- Plain text only`;\n\nconst notesUpdate = $json.intent + ' | Outreach sent via Cognflow AI Sales Agent.';\n\nreturn {\n  json: {\n    request_body: JSON.stringify({\n      model: \"claude-sonnet-4-5\",\n      max_tokens: 1024,\n      messages: [{ role: \"user\", content: content }]\n    }),\n    notion_update_body: JSON.stringify({\n      properties: {\n        Notes: {\n          rich_text: [{ text: { content: notesUpdate } }]\n        }\n      }\n    }),\n    lead_email: $json.email,\n    lead_name: $json.name,\n    score: $json.score,\n    intent: $json.intent,\n    suggested_service: $json.suggested_service,\n    notion_page_id: $('Create Notion Record.').item.json.id\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
