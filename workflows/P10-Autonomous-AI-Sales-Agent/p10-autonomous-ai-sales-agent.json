        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-5\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are a sales qualification agent for Cognflow, an n8n automation agency that builds AI-powered business workflows for SMEs.\\n\\nAnalyse this lead and return ONLY a valid JSON object with no markdown, no explanation, no code fences.\\n\\nLead details:\\n- Name: {{ $json.name }}\\n- Business: {{ $json.business }}\\n- Email: {{ $json.email }}\\n- Budget: ${{ $json.budget }}\\n- Pain Point: {{ $json.pain_point }}\\n- Source: {{ $json.source }}\\n\\nReturn this exact structure:\\n{\\n  \\\"score\\\": <integer 1-10>,\\n  \\\"qualified\\\": <true or false>,\\n  \\\"intent\\\": \\\"<one sentence summary of what they need>\\\",\\n  \\\"reason\\\": \\\"<one sentence explaining the score>\\\",\\n  \\\"suggested_service\\\": \\\"<the Cognflow service that best fits this lead>\\\"\\n}\\n\\nScoring rules:\\n- Score 7-10: Clear pain point, budget ≥ $500, automation use case fits n8n\\n- Score 4-6: Vague pain point or low budget or unclear fit\\n- Score 1-3: No clear automation need or budget too low\"\n    }\n  ]\n}",
        "options": {}
      },
