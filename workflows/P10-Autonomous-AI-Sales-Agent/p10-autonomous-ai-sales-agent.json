      "id": "17712b8f-5814-498b-9031-13c6d285de56",
      "name": "Build Email Prompt"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.content[0].text;\nconst lines = raw.split('\\n');\n\nconst subjectLine = lines.find(l => l.startsWith('Subject:'));\nconst subject = subjectLine ? subjectLine.replace('Subject:', '').trim() : 'Cognflow — Automation for Your Business';\nconst body = lines.filter(l => !l.startsWith('Subject:')).join('\\n').trim();\n\nreturn {\n  json: {\n    subject,\n    body,\n    lead_email: $('Build Email Prompt').item.json.lead_email,\n    lead_name: $('Build Email Prompt').item.json.lead_name,\n    score: $('Build Email Prompt').item.json.score,\n    intent: $('Build Email Prompt').item.json.intent,\n    suggested_service: $('Build Email Prompt').item.json.suggested_service,\n    notion_page_id: $('Build Email Prompt').item.json.notion_page_id\n  }\n};"
