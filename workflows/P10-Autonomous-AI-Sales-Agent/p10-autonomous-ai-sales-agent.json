    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.content[0].text;\nconst cleaned = raw.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\nconst parsed = JSON.parse(cleaned);\n\nreturn {\n  json: {\n    score: parsed.score,\n    qualified: parsed.qualified,\n    intent: parsed.intent,\n    reason: parsed.reason,\n    suggested_service: parsed.suggested_service,\n    name: $('Extract Lead Fields').item.json.name,\n    business: $('Extract Lead Fields').item.json.business,\n    email: $('Extract Lead Fields').item.json.email,\n    budget: $('Extract Lead Fields').item.json.budget,\n    pain_point: $('Extract Lead Fields').item.json.pain_point,\n    source: $('Extract Lead Fields').item.json.source\n  }\n};"
