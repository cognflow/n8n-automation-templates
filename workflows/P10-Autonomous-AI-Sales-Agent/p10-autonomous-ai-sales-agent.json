      "parameters": {
        "jsCode": "const blocks = $input.item.json.results;\n\nconst sopText = blocks\n  .map(block => {\n    const type = block.type;\n    const richText = block[type]?.rich_text || [];\n    return richText.map(rt => rt.plain_text).join('');\n  })\n  .filter(line => line.trim() !== '')\n  .join('\\n');\n\nreturn {\n  json: {\n    sop_context: sopText,\n   name: $('Parse Qualification.').item.json.name,\n    business: $('Parse Qualification.').item.json.business,\n    email: $('Parse Qualification.').item.json.email,\n    budget: $('Parse Qualification.').item.json.budget,\n    pain_point: $('Parse Qualification.').item.json.pain_point,\n    source: $('Parse Qualification.').item.json.source,\n    score: $('Parse Qualification.').item.json.score,\n    intent: $('Parse Qualification.').item.json.intent,\n    suggested_service: $('Parse Qualification.').item.json.suggested_service\n  }\n};"
